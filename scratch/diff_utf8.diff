+    const minX = Math.min(currentX, targetX) + bb.minX - spacing;
+    const maxX = Math.max(currentX, targetX) + bb.maxX + spacing;
+    const minY = Math.min(currentY, targetY) + bb.minY - spacing;
+    const maxY = Math.max(currentY, targetY) + bb.maxY + spacing;
