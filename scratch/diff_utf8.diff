+    let bestVal = safeVal;
+    
+    while (high - low > absStep) {
+      const mid = (low + high) / 2;
+      if (isSafe(mid)) {
+        bestVal = mid;
+        if (safeVal < unsafeVal) {
+          low = mid;
+        } else {
+          high = mid;
+        }
+      } else {
+        if (safeVal < unsafeVal) {
+          high = mid;
+        } else {
+          low = mid;
+        }
+      }
+    }
+    
+    return roundMetric(bestVal, 3);
+  }
