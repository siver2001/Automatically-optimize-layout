+  _findFirstSafeBinary(isSafe, unsafeVal, safeVal, step) {
+    if (!isSafe(safeVal)) return null;
+    
+    let low = Math.min(unsafeVal, safeVal);
+    let high = Math.max(unsafeVal, safeVal);
+    const absStep = Math.abs(step);
