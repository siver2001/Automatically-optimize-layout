+  _hasObstaclesInSweptBox(orient, currentX, currentY, targetX, targetY, spacing, spatialIndex) {
+    if (!spatialIndex || !spatialIndex.grid) return true; // Fallback to safe check if no grid index
+    
+    const bb = orient.bb || getBoundingBox(orient.polygon);
