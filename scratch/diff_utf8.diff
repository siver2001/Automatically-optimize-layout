+    const { grid, cellSize } = spatialIndex;
+    const x1 = Math.floor((minX - spacing) / cellSize);
+    const x2 = Math.floor((maxX + spacing) / cellSize);
+    const y1 = Math.floor((minY - spacing) / cellSize);
+    const y2 = Math.floor((maxY + spacing) / cellSize);
+    
+    const queryId = (spatialIndex.queryCount = (spatialIndex.queryCount || 0) + 1);
+    
+    for (let cy = y1; cy <= y2; cy++) {
+      for (let cx = x1; cx <= x2; cx++) {
+        const cell = grid.get(`${cx},${cy}`);
+        if (!cell) continue;
+        for (let i = 0; i < cell.length; i++) {
+          const entry = cell[i];
+          if (entry.lastQueryId === queryId) continue;
+          entry.lastQueryId = queryId;
+          
+          const entryP = entry.p;
+          const entryBB = entry.bb;
+          const minX1 = entryP.x + entryBB.minX - spacing;
+          const maxX1 = entryP.x + entryBB.maxX + spacing;
+          const minY1 = entryP.y + entryBB.minY - spacing;
+          const maxY1 = entryP.y + entryBB.maxY + spacing;
+          
+          if (!(maxX1 < minX || minX1 > maxX || maxY1 < minY || minY1 > maxY)) {
+            return true; // Overlaps!
+          }
+        }
+      }
+    }
+    
+    return false; // No obstacles!
+  }
